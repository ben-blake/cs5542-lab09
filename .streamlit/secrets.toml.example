# Streamlit Cloud secrets for Analytics Copilot
# Copy these values into the Streamlit Cloud dashboard under Settings > Secrets

SNOWFLAKE_ACCOUNT = "your_account_identifier"
SNOWFLAKE_USER = "your_username"
SNOWFLAKE_ROLE = "TRAINING_ROLE"
SNOWFLAKE_WAREHOUSE = "COPILOT_WH"
SNOWFLAKE_DATABASE = "ANALYTICS_COPILOT"

# Paste the CONTENTS of your private key file (not the file path)
SNOWFLAKE_PRIVATE_KEY = """
-----BEGIN PRIVATE KEY-----
paste your private key content here
-----END PRIVATE KEY-----
"""

# OR use password auth instead of private key:
# SNOWFLAKE_PASSWORD = "your_password"
